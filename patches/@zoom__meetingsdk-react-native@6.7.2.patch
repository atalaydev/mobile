 #import <React/RCTConvert.h>
 #import "RNZoomSDK.h"
+#import <objc/runtime.h>

+static void hideShareButtonInView(UIView *view) {
+    for (UIView *subview in view.subviews) {
+        if ([subview isKindOfClass:[UIButton class]]) {
+            UIButton *button = (UIButton *)subview;
+            UIImage *image = [button imageForState:UIControlStateNormal];
+            if (image && CGRectGetWidth(button.frame) < 60 && CGRectGetHeight(button.frame) < 60) {
+                CGPoint pos = [button convertPoint:button.bounds.origin toView:button.window];
+                if (pos.x > UIScreen.mainScreen.bounds.size.width / 2) {
+                    button.hidden = YES;
+                }
+            }
+        }
+        hideShareButtonInView(subview);
+    }
+}
+
+@implementation UIViewController (ZoomShareHide)
+
++ (void)load {
+    static dispatch_once_t onceToken;
+    dispatch_once(&onceToken, ^{
+        Class class = [self class];
+        SEL originalSelector = @selector(viewDidAppear:);
+        SEL swizzledSelector = @selector(zoom_viewDidAppear:);
+
+        Method originalMethod = class_getInstanceMethod(class, originalSelector);
+        Method swizzledMethod = class_getInstanceMethod(class, swizzledSelector);
+
+        BOOL didAdd = class_addMethod(class, originalSelector,
+                                       method_getImplementation(swizzledMethod),
+                                       method_getTypeEncoding(swizzledMethod));
+        if (didAdd) {
+            class_replaceMethod(class, swizzledSelector,
+                                method_getImplementation(originalMethod),
+                                method_getTypeEncoding(originalMethod));
+        } else {
+            method_exchangeImplementations(originalMethod, swizzledMethod);
+        }
+    });
+}
+
+- (void)zoom_viewDidAppear:(BOOL)animated {
+    [self zoom_viewDidAppear:animated];
+
+    NSString *className = NSStringFromClass([self class]);
+    if ([className containsString:@"MeetingInfo"] || [className containsString:@"meetinginfo"] || [className containsString:@"ZMInfo"]) {
+        dispatch_after(dispatch_time(DISPATCH_TIME_NOW, (int64_t)(0.1 * NSEC_PER_SEC)), dispatch_get_main_queue(), ^{
+            hideShareButtonInView(self.view);
+            self.navigationItem.rightBarButtonItem = nil;
+            self.navigationItem.rightBarButtonItems = @[];
+        });
+    }
+}
+
+@end
+
 @implementation RNZoomSDK

